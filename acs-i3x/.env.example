# -- Factory+ service discovery --
DIRECTORY_URL=https://directory.<your-base-url>

# -- Auth (username/password for local dev, keytabs in production) --
SERVICE_USERNAME=<your-username>
SERVICE_PASSWORD=<your-password>
REALM=<YOUR.KERBEROS.REALM>
# DEV_NO_AUTH=true disables Kerberos auth on incoming requests (local dev only)
# DEV_NO_AUTH=true

# -- HTTP server --
PORT=8080
HOSTNAME=localhost

# -- InfluxDB --
# If not exposed externally: kubectl port-forward svc/acs-influxdb2 8086:80
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=<your-influxdb-admin-token>
INFLUX_ORG=default
INFLUX_BUCKET=default

# -- i3X config --
I3X_NAMESPACE_NAME=<your-organisation-name>
I3X_NAMESPACE_URI=https://<your-base-url>/i3x
I3X_POLL_INTERVAL=60000
I3X_SUBSCRIPTION_TTL=300000
I3X_STALE_THRESHOLD=300000

# -- Logging --
LOG_LEVEL=info
