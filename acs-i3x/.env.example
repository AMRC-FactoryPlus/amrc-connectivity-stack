# -- Factory+ service discovery --
DIRECTORY_URL=

# -- Auth (username/password for local dev, keytabs in production) --
SERVICE_USERNAME=
SERVICE_PASSWORD=
REALM=
# DEV_NO_AUTH=true disables Kerberos auth on incoming requests (local dev only)
# DEV_NO_AUTH=true

# -- HTTP server --
PORT=8080
HOSTNAME=localhost

# -- InfluxDB --
# If not exposed externally: kubectl port-forward svc/acs-influxdb2 8086:80
INFLUX_URL=
INFLUX_TOKEN=
INFLUX_ORG=default
INFLUX_BUCKET=default

# -- i3X config --
I3X_NAMESPACE_NAME=
I3X_NAMESPACE_URI=
I3X_POLL_INTERVAL=60000
I3X_SUBSCRIPTION_TTL=300000
I3X_STALE_THRESHOLD=300000

# -- Logging --
LOG_LEVEL=info
