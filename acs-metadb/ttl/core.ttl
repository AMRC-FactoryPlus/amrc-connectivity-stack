<service/Auth> a <service/Service>; :primary <service/Service>;
    :uuid "cab2642a-f7d9-42e5-8845-8f35affe1fd4";
    :name "Auth service".
<service/Clusters> a <service/Service>; :primary <service/Service>;
    :uuid "2706aa43-a826-441e-9cec-cd3d4ce623c2";
